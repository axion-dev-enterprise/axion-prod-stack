TZ=America/Sao_Paulo

# Core paths
AXION_ROOT=/opt/axion
STACK_NAME=axion-platform
BASE_DOMAIN=axionenterprise.cloud
TENANT_BASE_DOMAIN=bot.axionenterprise.cloud

# Local-only host bindings for smoke/debug on the VPS
TRAEFIK_LOCAL_PORT=127.0.0.1:8088
GRAFANA_LOCAL_PORT=127.0.0.1:3300
KUMA_LOCAL_PORT=127.0.0.1:3301

# Cloudflare edge
CF_ENABLE=false
CF_TUNNEL_TOKEN=
CF_ACCOUNT_ID=
CF_API_TOKEN=

# R2 / restic
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=axion-backups
CF_R2_ENDPOINT=
CF_R2_REGION=auto
RESTIC_PASSWORD=
RESTIC_RETENTION_DAILY=14
RESTIC_RETENTION_WEEKLY=8
RESTIC_RETENTION_MONTHLY=6

# GitHub backup target
BACKUP_GITHUB_ENABLE=true
BACKUP_GITHUB_OWNER=axion-dev-enterprise
BACKUP_GITHUB_REPO=axion-prod-stack
BACKUP_GITHUB_BRANCH=backup-artifacts
BACKUP_GITHUB_TOKEN=

# Platform security
TRAEFIK_BASIC_AUTH=
INTERNAL_SHARED_TOKEN=
TENANT_ADMIN_TOKEN=

# Data services
VALKEY_PASSWORD=
POSTGRES_DB=axion
POSTGRES_USER=axion
POSTGRES_PASSWORD=
NATS_MONITOR_PORT=8222

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
HEALTHCHECKS_PING_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# Flow / product context
FLOW_PUBLIC_URL=https://flow.axionenterprise.cloud
FLOW_APP_NAME="AXION FLOW"

# Tenant defaults
PICOCLAW_IMAGE=docker.io/sipeed/picoclaw:latest
PICOCLAW_GATEWAY_PORT=18790
PICOCLAW_DEFAULT_MODEL=openrouter/xiaomi/mimo-v2-pro
PICOCLAW_DEFAULT_MAX_TOKENS=8192
PICOCLAW_DEFAULT_CONTEXT_WINDOW=262144
PICOCLAW_TOOL_FEEDBACK=true
PICOCLAW_ENABLE_EXEC=true
PICOCLAW_ENABLE_MCP=false
PICOCLAW_WEB_PROVIDER=auto

# LLM / provider defaults
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=

# Optional automation hooks
AXION_API_TOKEN=
AXION_PUBLIC_BASE_URL=
