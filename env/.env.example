TZ=America/Sao_Paulo

# Core paths
AXION_ROOT=/opt/axion
STACK_NAME=axion-platform
BASE_DOMAIN=axionenterprise.cloud
TENANT_BASE_DOMAIN=bot.axionenterprise.cloud

# Local-only host bindings for smoke/debug on the VPS
TRAEFIK_HTTP_BIND=127.0.0.1:8088
TRAEFIK_HTTPS_BIND=127.0.0.1:8443
GRAFANA_LOCAL_PORT=127.0.0.1:3300
KUMA_LOCAL_PORT=127.0.0.1:3301
ENABLE_OBSERVABILITY=false
ENABLE_STATUS=false

# Cloudflare edge
CF_ENABLE=false
CF_TUNNEL_TOKEN=
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_ZONE_ID=
PRIMARY_ORIGIN_IP=
SECONDARY_ORIGIN_IP=
CF_WORKERS_AI_BASE_URL=
CF_EMBED_MODEL=@cf/baai/bge-m3

# R2 / restic
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET=axion-backups
CF_R2_ENDPOINT=
CF_R2_REGION=auto
RESTIC_PASSWORD=
RESTIC_RETENTION_DAILY=14
RESTIC_RETENTION_WEEKLY=8
RESTIC_RETENTION_MONTHLY=6

# GitHub backup target
BACKUP_GITHUB_ENABLE=true
BACKUP_GITHUB_OWNER=axion-dev-enterprise
BACKUP_GITHUB_REPO=axion-prod-stack
BACKUP_GITHUB_BRANCH=backup-artifacts
BACKUP_GITHUB_TOKEN=

# Platform security
TRAEFIK_BASIC_AUTH=
INTERNAL_SHARED_TOKEN=
TENANT_ADMIN_TOKEN=

# Data services
VALKEY_PASSWORD=
POSTGRES_DB=axion
POSTGRES_USER=axion
POSTGRES_PASSWORD=
NATS_MONITOR_PORT=8222

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
HEALTHCHECKS_PING_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_WEBHOOK_URL=

# Flow / product context
FLOW_PUBLIC_URL=https://flow.axionenterprise.cloud
FLOW_APP_NAME="AXION FLOW"

# Tenant defaults
PICOCLAW_IMAGE=docker.io/sipeed/picoclaw:latest
PICOCLAW_GIT_REF=e556a816e4db4c158ab3a455693018f452f63eba
PICOCLAW_GATEWAY_PORT=18790
PICOCLAW_DEFAULT_MODEL=openrouter/xiaomi/mimo-v2-pro
PICOCLAW_UPSTREAM_MODEL=
PICOCLAW_DEFAULT_MAX_TOKENS=8192
PICOCLAW_DEFAULT_CONTEXT_WINDOW=262144
PICOCLAW_TOOL_FEEDBACK=true
PICOCLAW_ENABLE_EXEC=true
PICOCLAW_ENABLE_MCP=false
PICOCLAW_WEB_PROVIDER=auto

# LLM / provider defaults
FLOW_LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=

# Optional automation hooks
AXION_API_TOKEN=
AXION_PUBLIC_BASE_URL=

# FLOW budget assistant
FLOW_BUDGET_SERVER_URL=http://187.77.58.53:3456/gerar-orcamento
FLOW_BUDGET_SERVER_METHOD=POST
FLOW_BUDGET_SERVER_TOKEN=
FLOW_BUDGET_SERVER_TOKEN_HEADER=Authorization
FLOW_BUDGET_SERVER_HOST_HEADER=
FLOW_BUDGET_SERVER_DOWNLOAD_FIELD=pdf_url
FLOW_BUDGET_SERVER_FALLBACK_FIELDS=url,download_url,pdf
FLOW_BUDGET_ASSISTANT_NAME=Ana
FLOW_BUDGET_SCAN_ORIGIN=https://scan.axionenterprise.cloud

# Resource profile for 1 vCPU / 4 GB RAM
TRAEFIK_MEM_LIMIT=128m
TRAEFIK_CPUS=0.20
CLOUDFLARED_MEM_LIMIT=96m
CLOUDFLARED_CPUS=0.10

VALKEY_MEM_LIMIT=192m
VALKEY_CPUS=0.20
VALKEY_MAXMEMORY=128mb

NATS_MEM_LIMIT=192m
NATS_CPUS=0.20
NATS_MAX_MEMORY=64MB
NATS_MAX_FILE=1GB

POSTGRES_MEM_LIMIT=768m
POSTGRES_CPUS=0.60
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1024MB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_MAX_CONNECTIONS=40

KUMA_MEM_LIMIT=256m
KUMA_CPUS=0.25
LOKI_MEM_LIMIT=384m
LOKI_CPUS=0.30
ALLOY_MEM_LIMIT=192m
ALLOY_CPUS=0.20
GRAFANA_MEM_LIMIT=320m
GRAFANA_CPUS=0.35

PICOCLAW_TENANT_MEM_LIMIT=768m
PICOCLAW_TENANT_CPUS=0.70
PICOCLAW_OFFICIAL_MEM_LIMIT=768m
PICOCLAW_OFFICIAL_CPUS=0.70
QR_SCANNER_MEM_LIMIT=128m
QR_SCANNER_CPUS=0.15
QR_SCANNER_CONTAINER_PREFIX=picoclaw-
TENANT_CHAT_MEM_LIMIT=160m
TENANT_CHAT_CPUS=0.20
TENANT_CHAT_SITE_TITLE=AXION Tenant Chat
TENANT_CHAT_PICO_TOKEN=
